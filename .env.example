# ===========================================
# EU Border Risk Profiler - Configuration
# ===========================================

# Scheduler timezone
# -------------------
# Used by the harvester (daily run at 02:00) and predictor (daily run at 03:00).
# Containers default to UTC if unset, which can be confusing operationally.
# Use a tz database name, e.g. Europe/Paris, Europe/Brussels, UTC.
TZ=Europe/Paris

# Database Configuration
# -----------------------
DB_USER=user
DB_PASSWORD=password
DB_NAME=eubrp_db
DB_HOST=db
DB_PORT=5432

# Retry & Resilience Settings
# ----------------------------
# Maximum number of retry attempts for network/DB operations
RETRY_MAX_ATTEMPTS=3

# Initial backoff delay in seconds (doubles with each retry)
RETRY_BACKOFF_SECONDS=2

# Exit the service on failure (true) or keep retrying (false)
EXIT_ON_FAILURE=true

# Health Check Configuration
# ---------------------------
# Path to health status file for the harvester
HARVESTER_HEALTH_FILE=/tmp/harvester_health

# Path to health status file for the predictor
PREDICTOR_HEALTH_FILE=/tmp/predictor_health

# API health check endpoint URL
API_HEALTH_URL=http://localhost:8000/health

# Eurostat API Configuration
# ---------------------------
# L'API Eurostat est déjà configurée dans data_harvester/harvester.py
# URL de base: https://ec.europa.eu/eurostat/api/dissemination/statistics/1.0/data/migr_asyappctzm
# Dataset: migr_asyappctzm (Asylum applications - monthly data)
# 
# Les paramètres utilisés:
#   - applicant: NASY_APP (First-time applicants)
#   - age: TOTAL
#   - sex: T (Total)
#   - unit: PER (Persons)
#   - citizen: TOTAL
#   - lastTimePeriod: 60 (derniers 60 mois de données)
#
# AUCUNE CLÉ API N'EST REQUISE - L'API Eurostat est publique et gratuite
# Documentation: https://wikis.ec.europa.eu/display/EUROSTATHELP/API+Statistics+-+data+query

# Dashboard Configuration
# ------------------------
# URL de l'API backend (depuis le conteneur dashboard)
API_URL=http://api_service:8000

# Default dashboard language. Users can override at runtime via the
# in-app selector or by appending ?lang=en|et|fr to the URL. Supported
# values: en, et, fr. Falls back to "en" if unset or invalid.
DASHBOARD_DEFAULT_LANG=en

# API Authentication
# -------------------
# When set, the API requires every protected endpoint call to include this
# value in the X-API-Key header. Leave empty to keep the API open (legacy).
# Generate with e.g.: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=
